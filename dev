#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

show_help() {
  echo ""
  echo -e "${BOLD}${CYAN}Ottehr Development CLI${NC}"
  echo ""
  echo -e "${BOLD}Usage:${NC}"
  echo "  ./dev <command> [options]"
  echo ""
  echo -e "${BOLD}Configuration Commands:${NC}"
  echo "  use <profile> [workspace]    Switch to a configuration profile"
  echo "  who [-v]                     Show current configuration and health status"
  echo ""
  echo -e "${BOLD}Arguments:${NC}"
  echo "  profile    Configuration profile from configs/secrets/"
  echo "  workspace  Terraform workspace (default: local)"
  echo "             Syncs: {workspace}.tfvars + terraform workspace select"
  echo ""
  echo -e "${BOLD}Flags for 'use':${NC}"
  echo "  -c, --copy        Copy files instead of symlinks (for CI)"
  echo "  -v, --verbose     Show detailed file list"
  echo ""
  echo -e "${BOLD}Setup Commands:${NC}"
  echo "  clone secrets [branch]  Clone configuration profiles repository"
  echo ""
  echo -e "${BOLD}Examples:${NC}"
  echo "  ./dev use ottehr              # workspace: local (default)"
  echo "  ./dev use ottehr staging      # workspace: staging"
  echo "  ./dev use myprofile production  # workspace: production"
  echo "  ./dev use <profile> -v        # verbose output"
  echo "  ./dev use <profile> -c        # copy files (for CI)"
  echo "  ./dev who                     # Show config status"
  echo "  ./dev who -v                  # Show detailed config with file lists"
  echo "  ./dev clone secrets main      # Clone secrets from main branch"
  echo ""
}

cmd_clone() {
  local what="${1:-}"
  local branch="${2:-main}"

  if [[ "$what" != "secrets" ]]; then
    echo -e "${RED}Usage: ./dev clone secrets [branch]${NC}"
    exit 1
  fi

  local secrets_dir="$SCRIPT_DIR/configs/secrets"

  if [[ -d "$secrets_dir" ]]; then
    echo -e "${YELLOW}⚠${NC} configs/secrets/ already exists"
    echo ""
    echo "To update: cd configs/secrets && git pull"
    echo "To re-clone: rm -rf configs/secrets && ./dev clone secrets"
    exit 1
  fi

  echo -e "${BLUE}▸${NC} Cloning ottehr-secrets (branch: $branch)..."

  mkdir -p "$SCRIPT_DIR/configs"
  git clone --branch "$branch" git@github.com:masslight/ottehr-secrets.git "$secrets_dir"

  echo ""
  echo -e "${GREEN}✓${NC} Secrets cloned to configs/secrets/"
  echo ""
  echo "Next steps:"
  echo "  ./dev use ottehr        # Default config"
  echo "  ./dev use <profile>     # Extended profile"
}

cmd_use() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    echo -e "${RED}Usage: ./dev use <profile> [workspace] [-v]${NC}"
    echo ""
    echo "Available profiles:"
    if [[ -d "$SCRIPT_DIR/configs/secrets" ]]; then
      for d in "$SCRIPT_DIR"/configs/secrets/*/; do
        [[ -d "$d" ]] && echo "  $(basename "$d")"
      done
    else
      echo "  (Set up configs/secrets/ first - see configs/README.md)"
    fi
    echo ""
    echo "Workspaces: local (default), staging, production, e2e, development, testing, demo"
    exit 1
  fi

  npx tsx configs/scripts/use.ts "$@"
}

cmd_who() {
  npx tsx configs/scripts/who.ts "$@"
}

main() {
  local cmd="${1:-}"
  shift || true

  case "$cmd" in
    use)
      cmd_use "$@"
      ;;
    who)
      cmd_who "$@"
      ;;
    clone)
      cmd_clone "$@"
      ;;
    help|--help|-h|"")
      show_help
      ;;
    *)
      echo -e "${RED}Unknown command: $cmd${NC}"
      echo ""
      show_help
      exit 1
      ;;
  esac
}

main "$@"
